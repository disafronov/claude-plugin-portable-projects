{
  "description": "Portable memoir — ensure ~/.memoir symlinks point to portable slug dirs",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/ensure-symlink.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
